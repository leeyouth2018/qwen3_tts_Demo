[project]
requires = ["nodejs-24", "python3"]
template = "nextjs"
version = "0.0.14"
appliedPatches = []

[dev]
build = ["bash", "./scripts/prepare.sh"]
run = ["bash", "./scripts/start-voice-tts.sh"]
deps = ["git"]

[deploy]
build = ["bash", "./scripts/build.sh"]
run = ["bash", "./scripts/start.sh"]
deps = ["git"]
